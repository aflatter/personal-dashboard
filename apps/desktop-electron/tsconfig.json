{
  // Mirrors the collector's tsconfig — the Electron layer is written in the same
  // erasable-TS style Node 24 / Node 26 strip at runtime (explicit .ts import
  // specifiers, verbatim module syntax, no emit). Electron ships its own types;
  // "node" pulls in @types/node for the main-process builtins.
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "types": ["node", "electron"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"]
}
