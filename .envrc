# Auto-activate the devenv environment (Node 26 + pnpm) when you cd into the
# project, via direnv. Requires direnv + devenv — see README.md.
# `devenv direnvrc` provides the `use devenv` function, so this stays
# self-contained (no pinned source_url hash to maintain).
# https://devenv.sh/integrations/direnv/
eval "$(devenv direnvrc)"

use devenv
